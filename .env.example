# Optional: only needed for style-memory refresh. The final deterministic agent works without API quota.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TRANSCRIBE_MODEL=whisper-1

# Calendar event creation must be true for Google Calendar + Meet holds.
ALLOW_CALENDAR_CREATE=true

# WalkPA never sends email on the first pass. Follow-up sending requires explicit user checkbox approval.
ALLOW_EMAIL_SEND=false
